<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="49dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/razexr_title"
            android:layout_width="410dp"
            android:layout_height="match_parent"
            android:paddingBottom="20dp"
            android:text="RazeXR"
            android:textColor="@android:color/white"
            android:textSize="24sp" />

        <Button
            android:id="@+id/info_razexr"
            android:layout_width="41dp"
            android:layout_height="37dp"
            android:layout_weight="0"
            android:background="@drawable/ic_info" />

        <Button
            android:id="@+id/back_button"
            android:layout_width="41dp"
            android:layout_height="37dp"
            android:layout_weight="0"
            android:background="@drawable/ic_back" />

        <TextView
            android:id="@+id/textView5"
            android:layout_width="195dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />
    </LinearLayout>

    <Button
        android:id="@+id/button_razexr1"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bkg_dialog"
        android:text="Duke Nukem"
        android:textColor="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button_razexr2"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bkg_dialog"
            android:text="Blood"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/button_razexr3"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bkg_dialog"
            android:text="Exhumed-Powerslave"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button_razexr4"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bkg_dialog"
            android:text="NAM"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/button_razexr5"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bkg_dialog"
            android:text="Redneck Rampage"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button_razexr6"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bkg_dialog"
            android:text="Shadow Warrior"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/button_razexr7"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bkg_dialog"
            android:text="World War II GI"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <View
        android:layout_width="100dp"
        android:layout_height="20dp" />

    <Space
        android:layout_width="500dp"
        android:layout_height="1dp" />

</LinearLayout>
